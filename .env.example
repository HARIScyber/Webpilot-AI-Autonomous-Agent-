# .env.example — Environment Variables Template
# ================================================
# Copy this file to .env and fill in your real values.
#
#   Windows:  copy .env.example .env
#   Mac/Linux: cp .env.example .env
#
# IMPORTANT: Never commit your real .env file to Git.
# The .gitignore already excludes .env files.

# ---------------------------------------------------------------
# TinyFish API
# ---------------------------------------------------------------
# Get your API key from https://tinyfish.ai
# This is the only required value you MUST change.
TINYFISH_API_KEY=your-tinyfish-api-key-here

# The TinyFish SSE endpoint (don't change unless instructed)
TINYFISH_BASE_URL=https://agent.tinyfish.ai/v1/automation/run-sse

# How many seconds to wait before giving up on a task (default: 300 = 5 min)
TINYFISH_TIMEOUT=300

# ---------------------------------------------------------------
# Database
# ---------------------------------------------------------------
# SQLite (default, no setup needed — creates a local file):
DATABASE_URL=sqlite+aiosqlite:///./webpilot.db

# PostgreSQL (for production or if you want persistent data across containers):
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/webpilot

# ---------------------------------------------------------------
# Backend server
# ---------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# Set to False in production to disable Swagger UI and auto-reload
DEBUG=True

# ---------------------------------------------------------------
# CORS — which frontend origins are allowed
# ---------------------------------------------------------------
# Comma-separated list (no spaces between items)
# Add your deployed frontend URL here in production
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# ---------------------------------------------------------------
# Frontend (React)
# ---------------------------------------------------------------
# If your backend is on a different host/port, set this in frontend/.env:
# REACT_APP_API_URL=http://localhost:8000
